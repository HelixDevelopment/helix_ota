### STEP 3b: delta_artifacts structure
                                  Table "helix_ota.delta_artifacts"
       Column       |           Type           | Collation | Nullable |           Default            
--------------------+--------------------------+-----------+----------+------------------------------
 id                 | uuid                     |           | not null | gen_random_uuid()
 base_artifact_id   | uuid                     |           | not null | 
 target_artifact_id | uuid                     |           | not null | 
 delta_artifact_id  | uuid                     |           |          | 
 status             | character varying(50)    |           | not null | 'pending'::character varying
 file_path          | character varying(500)   |           |          | 
 file_size          | bigint                   |           |          | 
 checksum_sha256    | character(64)            |           |          | 
 savings_percent    | numeric(5,2)             |           |          | 
 partition_deltas   | jsonb                    |           | not null | '{}'::jsonb
 generation_errors  | jsonb                    |           |          | 
 created_at         | timestamp with time zone |           | not null | now()
 updated_at         | timestamp with time zone |           | not null | now()
Indexes:
    "delta_artifacts_pkey" PRIMARY KEY, btree (id)
    "delta_artifacts_base_target_uniq" UNIQUE CONSTRAINT, btree (base_artifact_id, target_artifact_id)
    "idx_delta_artifacts_base" btree (base_artifact_id)
    "idx_delta_artifacts_delta" btree (delta_artifact_id)
    "idx_delta_artifacts_status" btree (status)
    "idx_delta_artifacts_target" btree (target_artifact_id)
Check constraints:
    "delta_artifacts_base_ne_target_chk" CHECK (base_artifact_id <> target_artifact_id)
    "delta_artifacts_file_size_chk" CHECK (file_size IS NULL OR file_size > 0)
    "delta_artifacts_savings_chk" CHECK (savings_percent IS NULL OR savings_percent >= 0::numeric AND savings_percent <= 100::numeric)
    "delta_artifacts_sha256_chk" CHECK (checksum_sha256 IS NULL OR checksum_sha256 ~ '^[0-9a-f]{64}$'::text)
    "delta_artifacts_status_chk" CHECK (status::text = ANY (ARRAY['pending'::character varying, 'generating'::character varying, 'generated'::character varying, 'failed'::character varying, 'cancelled'::character varying]::text[]))
Foreign-key constraints:
    "delta_artifacts_base_fk" FOREIGN KEY (base_artifact_id) REFERENCES helix_ota.artifacts(id) ON DELETE CASCADE
    "delta_artifacts_delta_fk" FOREIGN KEY (delta_artifact_id) REFERENCES helix_ota.artifacts(id) ON DELETE CASCADE
    "delta_artifacts_target_fk" FOREIGN KEY (target_artifact_id) REFERENCES helix_ota.artifacts(id) ON DELETE CASCADE


